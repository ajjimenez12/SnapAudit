# SnapAudit now uses Supabase for Auth + Storage + database.
# These are safe to expose to the browser (the anon key is public by design).
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Optional local-only test harness. Leave false for normal development and production.
VITE_ENABLE_TEST_AUTH="false"
